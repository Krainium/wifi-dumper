@echo off
setlocal

:: wifi-passwords.bat — Dumps all saved Wi-Fi passwords to saved.txt
:: Works on Windows 7 / 8 / 10 / 11 — any language — no installs needed
:: Just double-click. Output: saved.txt (same folder as this script)

echo.
echo   WiFi Password Dumper
echo   ====================
echo.

:: Pass output path to PowerShell via environment variable
set "WIFI_OUT=%~dp0saved.txt"

:: Run embedded PowerShell (base64-encoded so quotes/special chars are safe)
powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -EncodedCommand 

echo.
pause
